{
  "name": "github-star-kit",
  "version": "0.0.1",
  "description": "AI-powered GitHub Star intelligence: personalized weekly digest + code context search across your starred repos. Browser extension + Obsidian plugin.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "yyymzzz <ylx121121@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/yyymzzz/github-star-kit"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r exec rm -rf dist build node_modules .turbo",
    "extension:dev": "pnpm --filter @starkit/extension dev",
    "extension:build": "pnpm --filter @starkit/extension build",
    "obsidian:dev": "pnpm --filter @starkit/obsidian dev",
    "obsidian:build": "pnpm --filter @starkit/obsidian build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "github",
    "stars",
    "ai",
    "semantic-search",
    "weekly-digest",
    "code-search",
    "browser-extension",
    "obsidian-plugin",
    "local-first",
    "byok"
  ]
}
